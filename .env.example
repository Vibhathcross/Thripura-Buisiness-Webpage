# ===========================================
# Thripura Offset Printers - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# MongoDB Connection (Primary Database)
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/database?retryWrites=true&w=majority
# For local MongoDB: mongodb://127.0.0.1:27017
MONGO_URI=mongodb://127.0.0.1:27017

# Application Port
PORT=3000

# Email Configuration (Gmail SMTP)
# Use an App Password: https://myaccount.google.com/apppasswords
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# SQLite Database Path (Alternative for Python backend)
SQLITE_DB_PATH=thripura_database.db

# Admin Credentials (for initial setup)
ADMIN_NAME=Madhu Sudhanan P K
ADMIN_PASSWORD=246Entry
